#!/bin/sh
# Pre-commit: validate k8s manifests (client-side schema) when kubectl is present.
set -eu
cd "$(git rev-parse --show-toplevel)"
if ! command -v kubectl >/dev/null 2>&1; then
  echo "[pre-commit] kubectl not found — skipping manifest validation" >&2
  exit 0
fi
rc=0
for f in $(git diff --cached --name-only --diff-filter=ACMR | grep -E '^manifests/.*\.ya?ml$' || true); do
  echo "[pre-commit] validate $f"
  git show ":$f" | kubectl apply --dry-run=client -f - >/dev/null 2>&1 || { echo "  INVALID: $f" >&2; rc=1; }
done
[ "$rc" = 0 ] && echo "[pre-commit] OK"
exit $rc
